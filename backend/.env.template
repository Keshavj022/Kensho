# =============================================================================
# Kensho - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.template .env
# =============================================================================

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# AZURE AI FOUNDRY (Optional - for AI agents)
# =============================================================================
# Get your connection string from: https://ai.azure.com
# Navigate to Project Settings -> Connection Strings
AZURE_AI_PROJECT_CONNECTION_STRING=your_azure_ai_foundry_connection_string_here
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_RESOURCE_GROUP=your_azure_resource_group
AZURE_PROJECT_NAME=your_azure_project_name

# =============================================================================
# AZURE SPEECH SERVICES (Optional - for voice interface)
# =============================================================================
# Get from Azure Portal: https://portal.azure.com
# Create a Speech resource and get the key and region
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# =============================================================================
# AZURE VISION SERVICES (Optional - for image analysis)
# =============================================================================
# Get from Azure Portal: https://portal.azure.com
# Create a Computer Vision resource
AZURE_VISION_KEY=your_azure_vision_key_here
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com

# =============================================================================
# AZURE BING SEARCH API (Optional - for web search)
# =============================================================================
# Get from Azure Portal: https://portal.azure.com
# Create a Bing Search v7 resource
AZURE_BING_SEARCH_KEY=your_azure_bing_search_key_here
AZURE_BING_SEARCH_ENDPOINT=https://your-resource.cognitiveservices.azure.com

# =============================================================================
# AZURE OPENAI (Required for RAG system embeddings)
# =============================================================================
# Get from Azure Portal: https://portal.azure.com
# Create an Azure OpenAI resource and get:
# 1. Endpoint URL (e.g., https://your-resource.openai.azure.com/)
# 2. API Key (from Keys and Endpoint section)
# 3. API Version (default: 2024-02-15-preview)
# 4. Deployment Name (the name of your embedding model deployment)
# Get from: https://platform.openai.com/api-keys
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=your-embedding-deployment-name

# OPENAI (Optional - fallback only, not recommended for production)
# Only used if Azure OpenAI is not configured
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# RESTAURANT APIs (At least one recommended for restaurant features)
# =============================================================================

# Google Places API (Recommended - most comprehensive)
# Get from: https://console.cloud.google.com/
# 1. Enable Places API
# 2. Create API key
# 3. Restrict key to Places API for security
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Yelp Fusion API (Alternative - good reviews and ratings)
# Get from: https://www.yelp.com/developers
# 1. Create app
# 2. Get API key
YELP_API_KEY=your_yelp_api_key_here

# Geoapify Places API (Free tier available - 3000 requests/day)
# Get from: https://www.geoapify.com/
# 1. Sign up (free tier available)
# 2. Get API key
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# =============================================================================
# TRAVEL APIs (Required for flight and hotel search)
# =============================================================================

# Amadeus API (Free tier available)
# Get from: https://developers.amadeus.com/
# 1. Create account (free tier available)
# 2. Create app to get API key and secret
# 3. Use test environment for development
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# =============================================================================
# WEB SEARCH APIs (Optional - for destination info and activities)
# =============================================================================

# Tavily API (AI-focused search, free tier available)
# Get from: https://tavily.com/
# 1. Sign up (free tier available)
# 2. Get API key
TAVILY_API_KEY=your_tavily_api_key_here

# Note: Azure Bing Search is listed above in Azure section

# =============================================================================
# NEO4J CONFIGURATION (Optional - for knowledge graph)
# =============================================================================
# Install Neo4j: https://neo4j.com/download/
# Or use Neo4j Aura (cloud): https://neo4j.com/cloud/aura/
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# =============================================================================
# JWT AUTHENTICATION (Required for user authentication)
# =============================================================================
# Generate a secure random string for production
# You can use: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production-use-env-var
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# MODEL CONFIGURATION (Optional - defaults provided)
# =============================================================================
DEFAULT_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large

# =============================================================================
# VECTOR STORE CONFIGURATION (Optional)
# =============================================================================
# Use "azure" for Azure AI Foundry or "chromadb" for local
VECTOR_STORE_TYPE=chromadb
CHROMADB_PATH=./chromadb_data

# =============================================================================
# CORS CONFIGURATION (Optional - defaults provided)
# =============================================================================
# Add your frontend URLs here (comma-separated)
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://yourdomain.com"]

# =============================================================================
# NOTES
# =============================================================================
# 1. All API keys marked as "Optional" can be omitted, but features will be limited
# 2. For restaurant features: At least one restaurant API key is recommended
# 3. For travel features: Amadeus API key and secret are required
# 4. For AI agents: Azure AI Foundry connection string is required
# 5. For knowledge graph: Neo4j is optional but recommended for personalization
# 6. For RAG system: OpenAI API key or Azure OpenAI is required
# 7. Never commit .env file to version control (it's in .gitignore)
# 8. Use strong, unique values for JWT_SECRET_KEY in production
