# Kensho backend (v2) — environment template.
# Copy to `.env` (repo root) and fill in the keys you have. Every key is OPTIONAL:
# a missing key disables only the corresponding tool — the app still boots and
# serves every other route. Never commit your real .env.

# ---------------- LLM (Google Gemini) ----------------
GEMINI_API_KEY=
# Current Gemini Flash model ID. Default is a GA model; override if you want a newer one.
GEMINI_MODEL=gemini-2.5-flash
# Stronger model used to escalate hard / low-quality menu OCR.
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ---------------- Open-source LLM fallback (Ollama) ----------------
# When enabled, a local Ollama model is used if a Gemini call fails (e.g. blocked
# key) or Gemini is unconfigured. Run `ollama serve` and `ollama pull <model>`.
# The chat model MUST support tool-calling (e.g. llama3.1, qwen2.5, mistral-nemo).
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_VISION_MODEL=llama3.2-vision
# Note: embeddings (dish search) still require GEMINI_API_KEY.

# ---------------- Tool backbone ----------------
# Maps/places, flights, hotels, shopping, photos, and Yelp menus ALL run on SerpApi.
# (google_maps, google_flights, google_hotels, google_maps_photos, google_shopping).
SERPAPI_API_KEY=
# GOOGLE_MAPS_API_KEY is no longer required (maps go through SerpApi). Leave unset.
# GOOGLE_MAPS_API_KEY=
# Tavily web search.
TAVILY_API_KEY=
# Tavily web search.
TAVILY_API_KEY=

# ---------------- Voice (ElevenLabs) ----------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v2

# ---------------- Knowledge graph (Neo4j) ----------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ---------------- Vector store / RAG (ChromaDB) ----------------
CHROMA_PATH=./chroma_data

# ---------------- Relational persistence ----------------
# sqlite for dev; swap to a postgres:// URL for prod.
DATABASE_URL=sqlite:///./kensho.db

# ---------------- Auth ----------------
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256

# ---------------- App ----------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=true
