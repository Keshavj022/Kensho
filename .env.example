# Kensho backend (v2) — environment template.
# Copy to `.env` (repo root) and fill in the keys you have. Every key is OPTIONAL:
# a missing key disables only the corresponding tool — the app still boots and
# serves every other route. Never commit your real .env.

# ---------------- LLM (Google Gemini) ----------------
GEMINI_API_KEY=
# Current Gemini Flash model ID. Default is a GA model; override if you want a newer one.
GEMINI_MODEL=gemini-2.5-flash
# Stronger model used to escalate hard / low-quality menu OCR.
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ---------------- Tool backbone ----------------
# Google Places API (New) — enable "Places API (New)" on this key.
GOOGLE_MAPS_API_KEY=
# SerpApi (google_flights, google_hotels, google_maps_photos, google_shopping, yelp_place).
SERPAPI_API_KEY=
# Tavily web search.
TAVILY_API_KEY=

# ---------------- Voice (ElevenLabs) ----------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v2

# ---------------- Knowledge graph (Neo4j) ----------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ---------------- Vector store / RAG (ChromaDB) ----------------
CHROMA_PATH=./chroma_data

# ---------------- Relational persistence ----------------
# sqlite for dev; swap to a postgres:// URL for prod.
DATABASE_URL=sqlite:///./kensho.db

# ---------------- Auth ----------------
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256

# ---------------- App ----------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=true
